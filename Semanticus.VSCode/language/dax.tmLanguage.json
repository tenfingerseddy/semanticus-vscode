{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "DAX",
  "scopeName": "source.dax",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#functions" },
    { "include": "#columnref" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.dax", "match": "//.*$" },
        { "name": "comment.line.double-dash.dax", "match": "--.*$" },
        { "name": "comment.block.dax", "begin": "/\\*", "end": "\\*/" }
      ]
    },
    "strings": {
      "name": "string.quoted.double.dax",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "name": "constant.character.escape.dax", "match": "\"\"" }
      ]
    },
    "numbers": {
      "name": "constant.numeric.dax",
      "match": "\\b\\d+(\\.\\d+)?([eE][+-]?\\d+)?\\b"
    },
    "keywords": {
      "patterns": [
        { "name": "keyword.control.dax", "match": "(?i)\\b(VAR|RETURN|DEFINE|EVALUATE|MEASURE|COLUMN|TABLE|ORDER\\s+BY|START\\s+AT|ASC|DESC)\\b" },
        { "name": "keyword.operator.logical.dax", "match": "(?i)\\b(IN|NOT|AND|OR)\\b" }
      ]
    },
    "constants": {
      "name": "constant.language.dax",
      "match": "(?i)\\b(TRUE|FALSE|BLANK)\\b"
    },
    "functions": {
      "name": "entity.name.function.dax",
      "match": "(?i)\\b([A-Z_][A-Z0-9_\\.]*)\\s*(?=\\()"
    },
    "columnref": {
      "match": "('[^']*'|[A-Za-z_][A-Za-z0-9_ ]*)?\\s*(\\[[^\\]]+\\])",
      "captures": {
        "1": { "name": "entity.name.type.table.dax" },
        "2": { "name": "variable.other.column.dax" }
      }
    },
    "operators": {
      "name": "keyword.operator.dax",
      "match": "(\\+|\\-|\\*|/|&&|\\|\\||&|<>|<=|>=|:=|=|<|>)"
    }
  }
}
