{
  "version": 1,
  "note": "Curated NUMBER-format-string templates (colour is report-side, out of scope). VBA/model-level tokens. Percentage rows assume a ratio (0-1) input. Dynamic (DAX) templates go in a dynamic format slot (a calculation item, or a measure's dynamic format string via set_measure_format_expression).",
  "categories": [
    "Whole numbers",
    "Decimals",
    "Percentages",
    "Currency",
    "Scaled (K/M/B/T)",
    "Signed / variance",
    "Change with Unicode indicators",
    "Accounting / parentheses",
    "Dates",
    "Times",
    "Durations",
    "KPI / indicator glyphs",
    "Ratios",
    "Basis points",
    "Custom units",
    "Blank / zero handling",
    "Scientific / specialty"
  ],
