    {
      "id": "scale-auto",
      "category": "Scaled (K/M/B/T)",
      "name": "Auto-scale (adaptive)",
      "description": "Tier switches by magnitude - impossible with a static string. Pattern: SQLBI.",
      "kind": "dynamic",
      "formatString": "VAR v=SELECTEDMEASURE() RETURN SWITCH(TRUE(), v<1E3,\"#,0\", v<1E6,\"#,0,.0\"\"K\"\"\", v<1E9,\"#,0,,.0\"\"M\"\"\", \"#,0,,,.0\"\"B\"\"\")",
      "sampleInput": "5000",
      "exampleOutput": "5.0K",
      "common": true,
      "note": "Tier switches by magnitude - impossible with a static string. Pattern: SQLBI.",
      "credit": null,
      "pack": null
    },
