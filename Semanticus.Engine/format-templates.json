    {
      "id": "dur-seconds-hhmmss",
      "category": "Durations",
      "name": "Seconds -> HH:MM:SS",
      "description": "Wrap in '...' to force a literal. Kurt/DaxLib HHMMSS.Seconds does this.",
      "kind": "dynamic",
      "formatString": "VAR s=SELECTEDMEASURE() RETURN \"'\" & FORMAT(QUOTIENT(s,3600),\"00\") & \":\" & FORMAT(QUOTIENT(MOD(s,3600),60),\"00\") & \":\" & FORMAT(MOD(s,60),\"00\") & \"'\"",
      "sampleInput": "3725",
      "exampleOutput": "01:02:05",
      "common": true,
      "note": "Wrap in '...' to force a literal. Kurt/DaxLib HHMMSS.Seconds does this.",
      "credit": "Kurt Buhler / DaxLib.FormatString",
      "pack": null
    },
    {
      "id": "dur-ms-adaptive",
      "category": "Durations",
      "name": "ms -> adaptive unit",
      "description": "MS-documented duration pattern; keeps the numeric type.",
      "kind": "dynamic",
      "formatString": "VAR ms=SELECTEDMEASURE() RETURN SWITCH(TRUE(), ms<1000, FORMAT(ms,\"#,0\")&\" \\m\\s\", ms<60000, \"'\"&FORMAT(ms/1000,\"#,0.0\")&\" s'\", ms<3600000, \"'\"&FORMAT(ms/60000,\"#,0.0\")&\" m'\", \"'\"&FORMAT(ms/3600000,\"#,0.0\")&\" h'\")",
      "sampleInput": "5000",
      "exampleOutput": "5.0 s",
      "common": false,
      "note": "MS-documented duration pattern; keeps the numeric type.",
      "credit": null,
      "pack": null
    },
